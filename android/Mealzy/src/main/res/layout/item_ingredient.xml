<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/selector_card_stroke">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Ingredient Name -->
        <TextView
            android:id="@+id/text_ingredient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            app:layout_constraintEnd_toStartOf="@+id/switch_available"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Chicken Breast" />

        <!-- Availability Switch -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_available"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Category Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            app:chipMinHeight="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_ingredient_name"
            tools:text="Protein" />

        <!-- Quantity -->
        <TextView
            android:id="@+id/text_quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/chip_category"
            tools:text="2 lbs" />

        <!-- Low Stock Warning Icon (next to quantity) -->
        <ImageView
            android:id="@+id/icon_low_stock"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/low_stock"
            android:src="@drawable/ic_warning_small"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/text_quantity"
            app:layout_constraintStart_toEndOf="@+id/text_quantity"
            app:layout_constraintTop_toTopOf="@+id/text_quantity"
            tools:visibility="visible" />

        <!-- Low Stock Label -->
        <TextView
            android:id="@+id/text_low_stock_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="@string/low_stock"
            android:textSize="11sp"
            android:textColor="@color/warning_color"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@+id/icon_low_stock"
            app:layout_constraintTop_toTopOf="@+id/icon_low_stock"
            app:layout_constraintBottom_toBottomOf="@+id/icon_low_stock"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
